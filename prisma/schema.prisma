generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model FollowUpTask {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  job_id     String    @db.Uuid
  title      String?
  due_date   DateTime? @db.Date
  completed  Boolean?
  created_at DateTime? @default(dbgenerated("(now() AT TIME ZONE 'utc'::text)")) @db.Timestamptz(6)
  Job        Job       @relation(fields: [job_id], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Interview {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  job_id       String   @db.Uuid
  scheduled_at DateTime @db.Date
  round_type   String
  notes        String?
  created_at   DateTime @default(dbgenerated("(now() AT TIME ZONE 'utc'::text)")) @db.Timestamptz(6)
  Job          Job      @relation(fields: [job_id], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model Job {
  id                      String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id                 String
  title                   String
  company_name            String
  location                String
  pipeline_stage          String
  last_activity_date      DateTime               @db.Date
  deadline                DateTime?              @db.Date
  priority_flag           Boolean?
  job_description         String?
  compensation_notes      String?
  application_date        DateTime?              @db.Date
  recruiter_contact_notes String?
  custom_notes            String?
  created_at              DateTime               @default(dbgenerated("(now() AT TIME ZONE 'utc'::text)")) @db.Timestamptz(6)
  updated_at              DateTime               @default(dbgenerated("(now() AT TIME ZONE 'utc'::text)")) @db.Timestamptz(6)
  FollowUpTask            FollowUpTask[]
  Interview               Interview[]
  User                    User                   @relation(fields: [user_id], references: [id], onDelete: Cascade)
  PipelineStageHistory    PipelineStageHistory[]
  TimelineEvent           TimelineEvent[]
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model PipelineStageHistory {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  job_id     String    @db.Uuid
  from_stage String?
  to_stage   String?
  changed_at DateTime? @default(dbgenerated("(now() AT TIME ZONE 'utc'::text)")) @db.Timestamptz(6)
  outcome_at DateTime? @default(dbgenerated("(now() AT TIME ZONE 'utc'::text)")) @db.Timestamptz(6)
  Job        Job       @relation(fields: [job_id], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model TimelineEvent {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  job_id      String    @db.Uuid
  event_type  String?
  notes       String?
  occurred_at DateTime? @db.Timestamp(6)
  Job         Job       @relation(fields: [job_id], references: [id], onDelete: Cascade)
}

/// This model contains row level security and requires additional setup for migrations. Visit https://pris.ly/d/row-level-security for more info.
model User {
  id             String    @id
  email          String    @unique
  hashedPassword String
  firstName      String?
  lastName       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  Job            Job[]
  Profile        Profile?
}

model Profile {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @unique
  phone     String?
  location  String?
  linkedIn  String?
  headline  String?
  bio       String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  User      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum job_activity_type {
  Interview
  Tasks
  Events
}

/// This enum is commented in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
enum stage {
  Interested
  Applied
  Interview
  Offer
  Rejected
  Archived
}
